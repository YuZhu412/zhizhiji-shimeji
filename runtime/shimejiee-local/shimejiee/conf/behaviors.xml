<?xml version="1.0" encoding="UTF-8"?>
<Mascot xmlns="http://www.group-finity.com/Mascot">
  <BehaviorList>

    <Behavior Name="Stand" Frequency="50">
      <NextBehaviorList Add="true">
        <BehaviorReference Name="WalkLeft"  Frequency="25"/>
        <BehaviorReference Name="WalkRight" Frequency="25"/>
        <BehaviorReference Name="Stand"     Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WalkLeft" Frequency="25">
      <NextBehaviorList Add="true">
        <BehaviorReference Name="Stand"      Frequency="30"/>
        <BehaviorReference Name="WalkLeft"   Frequency="40"/>
        <BehaviorReference Name="WalkRight"  Frequency="30"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WalkRight" Frequency="25">
      <NextBehaviorList Add="true">
        <BehaviorReference Name="Stand"      Frequency="30"/>
        <BehaviorReference Name="WalkLeft"   Frequency="30"/>
        <BehaviorReference Name="WalkRight"  Frequency="40"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Fall" Frequency="0" Hidden="true" />
    <Behavior Name="Dragged" Frequency="0" Hidden="true" />
    <Behavior Name="Thrown" Frequency="0" Hidden="true" />

  </BehaviorList>
</Mascot>
