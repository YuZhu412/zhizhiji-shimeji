<?xml version="1.0" encoding="UTF-8"?>
<Mascot xmlns="http://www.group-finity.com/Mascot">
  <BehaviorList>

    <!-- Stand 在低频次轮询时，优先判定是否贴墙、是否广播被扫描、否则再走/休闲 -->
    <Behavior Name="Stand" Frequency="15" Action="Stand">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="ScanGreet" Frequency="45"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 150 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 150}"/>
        <BehaviorReference Name="WalkLeft"  Frequency="20"/>
        <BehaviorReference Name="WalkRight" Frequency="20"/>
        <BehaviorReference Name="Sleep"     Frequency="12"/>
        <BehaviorReference Name="Eat"       Frequency="12"/>
        <BehaviorReference Name="PipiPlay"  Frequency="12"/>
        <BehaviorReference Name="Stand"     Frequency="35"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="StandRight" Frequency="15" Action="StandRight">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="ScanGreet"  Frequency="45"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 150 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 150}"/>
        <BehaviorReference Name="WalkLeft"   Frequency="20"/>
        <BehaviorReference Name="WalkRight"  Frequency="20"/>
        <BehaviorReference Name="Sleep"      Frequency="12"/>
        <BehaviorReference Name="Eat"        Frequency="12"/>
        <BehaviorReference Name="PipiPlay"   Frequency="12"/>
        <BehaviorReference Name="StandRight" Frequency="35"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WalkLeft" Frequency="35" Action="WalkLeft">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft" Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="ScanGreet"  Frequency="45"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 150 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 150}"/>
        <BehaviorReference Name="Laugh"      Frequency="15"/>
        <BehaviorReference Name="Stand"      Frequency="13"/>
        <BehaviorReference Name="StandRight" Frequency="13"/>
        <BehaviorReference Name="WalkLeft"   Frequency="20"/>
        <BehaviorReference Name="WalkRight"  Frequency="20"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WalkRight" Frequency="35" Action="WalkRight">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="ScanGreet"  Frequency="45"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 150 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 150}"/>
        <BehaviorReference Name="Laugh"      Frequency="15"/>
        <BehaviorReference Name="Stand"      Frequency="13"/>
        <BehaviorReference Name="StandRight" Frequency="13"/>
        <BehaviorReference Name="WalkLeft"   Frequency="20"/>
        <BehaviorReference Name="WalkRight"  Frequency="20"/>
      </NextBehaviorList>
    </Behavior>

    <!-- 大笑挥手：播放完毕后回到 Stand/StandRight -->
    <Behavior Name="Laugh" Frequency="0" Action="Laugh">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Sleep" Frequency="0" Action="Sleep">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Eat" Frequency="0" Action="Eat">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="PipiPlay" Frequency="0" Action="PipiPlay">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- ScanGreet：zhi 扫描持 "greet" 的 ham 并追过去 -->
    <Behavior Name="ScanGreet" Frequency="0" Action="ScanGreet">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- GreetAct：仅能被 ScanMove 的 Behavior 强制跳转，不自然触发 -->
    <Behavior Name="GreetAct" Frequency="0" Action="GreetAct">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- WallCling: stays until mouse click -->
    <Behavior Name="WallClingLeft" Frequency="0" Action="WallClingLeft">
      <NextBehaviorList>
        <BehaviorReference Name="Stand" Frequency="100"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WallClingRight" Frequency="0" Action="WallClingRight">
      <NextBehaviorList>
        <BehaviorReference Name="Stand" Frequency="100"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Fall" Frequency="0" Action="Fall">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="1"/>
        <BehaviorReference Name="StandRight" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Dragged" Frequency="0" Action="Dragged">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="1"/>
        <BehaviorReference Name="StandRight" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Thrown" Frequency="0" Action="Thrown">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 200}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 200}"/>
        <BehaviorReference Name="Fall" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

  </BehaviorList>
</Mascot>
