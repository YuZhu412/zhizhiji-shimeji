<?xml version="1.0" encoding="UTF-8"?>
<Mascot xmlns="http://www.group-finity.com/Mascot">
  <BehaviorList>

    <!-- Stand/StandRight 鍚勮嚜鍙烦鍥炶嚜宸憋紝纭繚 idle 鏈熼棿鏂瑰悜涓嶅彉 -->
    <Behavior Name="Stand" Frequency="15" Action="Stand">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 70}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 70}"/>
        <BehaviorReference Name="WalkLeft"  Frequency="10"/>
        <BehaviorReference Name="WalkRight" Frequency="10"/>
        <BehaviorReference Name="Sleep"     Frequency="15"/>
        <BehaviorReference Name="Eat"       Frequency="15"/>
        <BehaviorReference Name="Stand"     Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- 姘村钩缈昏浆鐗?idle锛岃繘鍏ユ椂闅忔満閫夊埌姝ゅ垯鏈濆彸锛屼箣鍚庝竴鐩翠繚鎸?-->
    <Behavior Name="StandRight" Frequency="15" Action="StandRight">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 70}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 70}"/>
        <BehaviorReference Name="WalkLeft"   Frequency="10"/>
        <BehaviorReference Name="WalkRight"  Frequency="10"/>
        <BehaviorReference Name="Sleep"      Frequency="15"/>
        <BehaviorReference Name="Eat"        Frequency="15"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- 璧拌矾缁撴潫鍚庢湁姒傜巼瑙﹀彂澶х瑧鎸ユ墜 -->
    <Behavior Name="WalkLeft" Frequency="35" Action="WalkLeft">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft" Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 70}"/>
        <BehaviorReference Name="Laugh"      Frequency="15"/>
        <BehaviorReference Name="Stand"      Frequency="13"/>
        <BehaviorReference Name="StandRight" Frequency="13"/>
        <BehaviorReference Name="WalkLeft"   Frequency="20"/>
        <BehaviorReference Name="WalkRight"  Frequency="20"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WalkRight" Frequency="35" Action="WalkRight">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 70}"/>
        <BehaviorReference Name="Laugh"      Frequency="15"/>
        <BehaviorReference Name="Stand"      Frequency="13"/>
        <BehaviorReference Name="StandRight" Frequency="13"/>
        <BehaviorReference Name="WalkLeft"   Frequency="20"/>
        <BehaviorReference Name="WalkRight"  Frequency="20"/>
      </NextBehaviorList>
    </Behavior>

    <!-- 澶х瑧鎸ユ墜锛氭挱鏀惧畬姣曞悗鍥炲埌 Stand/StandRight -->
    <Behavior Name="Laugh" Frequency="0" Action="Laugh">
      <NextBehaviorList>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- 鐫¤锛氭挱鏀惧畬姣曞悗鍥炲埌 Stand/StandRight -->
    <Behavior Name="Sleep" Frequency="0" Action="Sleep">
      <NextBehaviorList>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>


    <!-- 吃饭：播放完毕后回到 Stand/StandRight -->
    <Behavior Name="Eat" Frequency="0" Action="Eat">
      <NextBehaviorList>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- WallCling: stays until mouse click -->
    <Behavior Name="WallClingLeft" Frequency="0" Action="WallClingLeft">
      <NextBehaviorList>
        <BehaviorReference Name="Stand" Frequency="100"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WallClingRight" Frequency="0" Action="WallClingRight">
      <NextBehaviorList>
        <BehaviorReference Name="Stand" Frequency="100"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Fall" Frequency="0" Action="Fall">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 70}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 70}"/>
        <BehaviorReference Name="Stand"      Frequency="1"/>
        <BehaviorReference Name="StandRight" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Dragged" Frequency="0" Action="Dragged">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 70}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 70}"/>
        <BehaviorReference Name="Stand"      Frequency="1"/>
        <BehaviorReference Name="StandRight" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Thrown" Frequency="0" Action="Thrown">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 75}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 75}"/>
        <BehaviorReference Name="Fall" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

  </BehaviorList>
</Mascot>
