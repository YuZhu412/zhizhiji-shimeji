<?xml version="1.0" encoding="UTF-8"?>
<Mascot xmlns="http://www.group-finity.com/Mascot">
  <BehaviorList>

    <!-- Stand/StandRight 各自只跳回自己，确保 idle 期间方向不变 -->
    <Behavior Name="Stand" Frequency="15" Action="Stand">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="GreetWait" Frequency="40"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 200 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 200}"/>
        <BehaviorReference Name="WalkLeft"  Frequency="25"/>
        <BehaviorReference Name="WalkRight" Frequency="25"/>
        <BehaviorReference Name="Stand"     Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <!-- 水平翻转版 idle，进入时随机选到此则朝右，之后一直保持 -->
    <Behavior Name="StandRight" Frequency="15" Action="StandRight">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="GreetWait"  Frequency="40"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 200 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 200}"/>
        <BehaviorReference Name="WalkLeft"   Frequency="25"/>
        <BehaviorReference Name="WalkRight"  Frequency="25"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WalkLeft" Frequency="35" Action="WalkLeft">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft" Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="GreetWait"  Frequency="40"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 200 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 200}"/>
        <BehaviorReference Name="Stand"      Frequency="15"/>
        <BehaviorReference Name="StandRight" Frequency="15"/>
        <BehaviorReference Name="WalkLeft"   Frequency="20"/>
        <BehaviorReference Name="WalkRight"  Frequency="20"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WalkRight" Frequency="35" Action="WalkRight">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="GreetWait"  Frequency="40"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.left + 200 &amp;&amp; mascot.anchor.x &lt; mascot.environment.workArea.right - 200}"/>
        <BehaviorReference Name="Stand"      Frequency="15"/>
        <BehaviorReference Name="StandRight" Frequency="15"/>
        <BehaviorReference Name="WalkLeft"   Frequency="20"/>
        <BehaviorReference Name="WalkRight"  Frequency="20"/>
      </NextBehaviorList>
    </Behavior>

    <!-- WallCling: stays until mouse click -->
    <Behavior Name="WallClingLeft" Frequency="0" Action="WallClingLeft">
      <NextBehaviorList>
        <BehaviorReference Name="Stand" Frequency="100"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="WallClingRight" Frequency="0" Action="WallClingRight">
      <NextBehaviorList>
        <BehaviorReference Name="Stand" Frequency="100"/>
      </NextBehaviorList>
    </Behavior>

    <!-- ham 偶尔进入等待状态，广播 "greet" 供 zhizhiji 扫描 -->
    <Behavior Name="GreetWait" Frequency="0" Action="GreetWait">
      <NextBehaviorList>
        <BehaviorReference Name="Stand" Frequency="100"/>
      </NextBehaviorList>
    </Behavior>

    <!-- 仅能被 ScanMove 的 TargetBehavior 强制跳转，不自然触发 -->
    <Behavior Name="GreetReact" Frequency="0" Action="GreetReact">
      <NextBehaviorList>
        <BehaviorReference Name="Stand"      Frequency="50"/>
        <BehaviorReference Name="StandRight" Frequency="50"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Fall" Frequency="0" Action="Fall">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="1"/>
        <BehaviorReference Name="StandRight" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Dragged" Frequency="0" Action="Dragged">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 130}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 130}"/>
        <BehaviorReference Name="Stand"      Frequency="1"/>
        <BehaviorReference Name="StandRight" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

    <Behavior Name="Thrown" Frequency="0" Action="Thrown">
      <NextBehaviorList>
        <BehaviorReference Name="WallClingLeft"  Frequency="9999"
            Condition="#{mascot.anchor.x &lt; mascot.environment.workArea.left + 200}"/>
        <BehaviorReference Name="WallClingRight" Frequency="9999"
            Condition="#{mascot.anchor.x &gt; mascot.environment.workArea.right - 200}"/>
        <BehaviorReference Name="Fall" Frequency="1"/>
      </NextBehaviorList>
    </Behavior>

  </BehaviorList>
</Mascot>
